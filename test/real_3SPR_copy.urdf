<?xml version="1.0" encoding="utf-8"?>
<robot name="3SPR_Parallel_Robot">

  <!-- ==================== 材质定义 ==================== -->
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>
  <material name="cyan">
    <color rgba="0.0 0.8 0.8 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 0.8"/>
  </material>

  <!-- ==================== BASE (定平台) ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.2" radius="4.5"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="100.0"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <inertia ixx="10.0" ixy="0.0" ixz="0.0" iyy="10.0" iyz="0.0" izz="20.0"/>
    </inertial>
  </link>

  <!-- ==================== LEG 1 (主链：负责连接动平台) ==================== -->
  <joint name="leg1_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg1_s1"/>
    <origin xyz="3.88675 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.866025 0.0 -0.5"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg1_s1">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="leg1_joint2" type="revolute">
    <parent link="leg1_s1"/>
    <child link="leg1_s2"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg1_s2">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="leg1_joint3" type="revolute">
    <parent link="leg1_s2"/>
    <child link="leg1_s3"/>
    <axis xyz="-0.5 0.0 -0.866025"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg1_s3">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="leg1_joint4" type="prismatic">
    <parent link="leg1_s3"/>
    <child link="leg1_lower"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.523599 0.0"/>
    <axis xyz="0.0 0.0 -1.0"/>
    <limit lower="-2.0" upper="1.0" effort="5000.0" velocity="2.0"/>
  </joint>
  <link name="leg1_lower">
    <visual>
      <origin xyz="0.0 0.0 -1.88675" rpy="0.0 0.0 0.0"/>
      <geometry><cylinder length="7.7735" radius="0.1"/></geometry>
      <material name="cyan"/>
    </visual>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0.0 0.0 -1.88675" rpy="0.0 0.0 0.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="leg1_joint5" type="revolute">
    <parent link="leg1_lower"/>
    <child link="motion_link"/>
    <origin xyz="0.0 0.0 -5.7735" rpy="1.570796 -0.523599 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>

  <!-- ==================== MOVING PLATFORM (动平台) ==================== -->
  <link name="motion_link">
    <visual>
      <origin xyz="-1 0.0 0.0" rpy="1.570796 0.0 0.0"/>
      <geometry><cylinder length="0.2" radius="1.5"/></geometry>
      <material name="red"/>
    </visual>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="2.0"/>
    </inertial>
  </link>

  <!-- 动平台上的闭环锚点 -->
  <joint name="leg2_anchor_joint" type="fixed">
    <parent link="motion_link"/>
    <child link="leg2_anchor_frame"/>
    <origin xyz="-1.5 0 -0.866025" rpy="0 -2.094395 0"/>
  </joint>
  <link name="leg2_anchor_frame">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/></inertial>
  </link>

  <joint name="leg3_anchor_joint" type="fixed">
    <parent link="motion_link"/>
    <child link="leg3_anchor_frame"/>
    <origin xyz="-1.5 0 0.866025 " rpy="0.0 2.094395 0.0"/>
  </joint>
  <link name="leg3_anchor_frame">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/></inertial>
  </link>

  <!-- ==================== LEG 2 (从链：末端悬空) ==================== -->
  <joint name="leg2_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg2_s1"/>
    <origin xyz="-1.943376 3.366025 0.0" rpy="0.0 0.0 2.094395"/>
    <axis xyz="0.866025 0.0 -0.5"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg2_s1">
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/></inertial>
  </link>

  <joint name="leg2_joint2" type="revolute">
    <parent link="leg2_s1"/>
    <child link="leg2_s2"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg2_s2">
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/></inertial>
  </link>

  <joint name="leg2_joint3" type="revolute">
    <parent link="leg2_s2"/>
    <child link="leg2_s3"/>
    <axis xyz="-0.5 0.0 -0.866025"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg2_s3">
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/></inertial>
  </link>

  <joint name="leg2_joint4" type="prismatic">
    <parent link="leg2_s3"/>
    <child link="leg2_lower"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.523599 0.0"/>
    <axis xyz="0.0 0.0 -1.0"/>
    <limit lower="-2.0" upper="1.0" effort="5000.0" velocity="2.0"/>
  </joint>
  <link name="leg2_lower">
    <visual>
      <origin xyz="0.0 0.0 -1.88675" rpy="0.0 0.0 0.0"/>
      <geometry><cylinder length="7.7735" radius="0.1"/></geometry>
      <material name="cyan"/>
    </visual>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0.0 0.0 -1.88675" rpy="0.0 0.0 0.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="leg2_joint5" type="revolute">
    <parent link="leg2_lower"/>
    <child link="leg2_tip_frame"/>
    <origin xyz="0.0 0.0 -5.7735" rpy="1.570796 -0.523599 2.094395"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg2_tip_frame">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/></inertial>
  </link>

  <!-- ==================== LEG 3 (从链：末端悬空) ==================== -->
  <joint name="leg3_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg3_s1"/>
    <origin xyz="-1.943376 -3.366025 0.0" rpy="0.0 0.0 -2.094395"/>
    <axis xyz="0.866025 0.0 -0.5"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg3_s1">
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/></inertial>
  </link>

  <joint name="leg3_joint2" type="revolute">
    <parent link="leg3_s1"/>
    <child link="leg3_s2"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg3_s2">
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/></inertial>
  </link>

  <joint name="leg3_joint3" type="revolute">
    <parent link="leg3_s2"/>
    <child link="leg3_s3"/>
    <axis xyz="-0.5 0.0 -0.866025"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg3_s3">
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/></inertial>
  </link>

  <joint name="leg3_joint4" type="prismatic">
    <parent link="leg3_s3"/>
    <child link="leg3_lower"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.523599 0.0"/>
    <axis xyz="0.0 0.0 -1.0"/>
    <limit lower="-2.0" upper="1.0" effort="5000.0" velocity="2.0"/>
  </joint>
  <link name="leg3_lower">
    <visual>
      <origin xyz="0.0 0.0 -1.88675" rpy="0.0 0.0 0.0"/>
      <geometry><cylinder length="7.7735" radius="0.1"/></geometry>
      <material name="cyan"/>
    </visual>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0.0 0.0 -1.88675" rpy="0.0 0.0 0.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="leg3_joint5" type="revolute">
    <parent link="leg3_lower"/>
    <child link="leg3_tip_frame"/>
    <origin xyz="0.0 0.0 -5.7735" rpy="1.570796 -0.523599 0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>
  <link name="leg3_tip_frame">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/></inertial>
  </link>

</robot>