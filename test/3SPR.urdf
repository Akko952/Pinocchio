<?xml version="1.0" ?>
<!-- 
    Single Leg Open Kinematic Chain.
    The platform has been removed for simplicity.
-->
<robot name="Single_Leg_Open_Chain">

  <!-- Materials -->
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1"/></material>
  <material name="cyan"><color rgba="0.0 0.8 0.8 1"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1"/></material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.2" radius="4.5"/></geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="1000.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="200"/>
    </inertial>
  </link>
  
  <!-- ==================== LEG 1 (Open Chain) ==================== -->
  <!-- S-Joint Part 1 -->
  <joint name="leg1_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg1_link1"/>
    <origin xyz="3.887 0 0" rpy="0 0 0"/>
    <axis xyz="0.866025404 0 -0.500000000"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="0"/>
  </joint>
  <link name="leg1_link1">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <!-- S-Joint Part 2 -->
  <joint name="leg1_joint2" type="revolute">
    <parent link="leg1_link1"/>
    <child link="leg1_link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="0"/>
  </joint>
  <link name="leg1_link2">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <!-- S-Joint Part 3 -->
  <joint name="leg1_joint3" type="revolute">
    <parent link="leg1_link2"/>
    <child link="leg1_s_joint_end"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-0.500000000 0 -0.866025404"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="0"/>
  </joint>
  <link name="leg1_s_joint_end">
     <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <!-- Fixed joint to apply initial downward rotation -->
  <joint name="leg1_orientation_fix" type="fixed">
    <parent link="leg1_s_joint_end"/>
    <child link="leg1_upper"/>
    <origin xyz="0 0 0" rpy="0 0.523599 0"/> <!-- Pitch by 30 degrees -->
  </joint>
  
  <link name="leg1_upper">
    <visual>
      <origin xyz="0 0 -1" rpy="0 0 0"/>
      <geometry><cylinder length="2.0" radius="0.15"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 -1"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Prismatic joint axis is now along the new Z-axis -->
  <joint name="leg1_joint4" type="prismatic">
    <parent link="leg1_upper"/>
    <child link="leg1_lower"/>
    <origin xyz="0 0 -1" rpy="0 0 0"/> <!-- Start at the end of the upper link -->
    <axis xyz="0 0 -1"/>
    <limit lower="-1" upper="2.0" effort="5000" velocity="2.0"/>
  </joint>

  <link name="leg1_lower">
    <visual>
      <origin xyz="0 0 -1.5" rpy="0 0 0"/>
      <geometry><cylinder length="3.773502692" radius="0.1"/></geometry>
      <material name="cyan"/>
    </visual>
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 -1.5"/>
      <inertia ixx="0.8" ixy="0" ixz="0" iyy="0.8" iyz="0" izz="0.05"/>
    </inertial>
  </link>
  <!-- End of the kinematic chain -->

</robot>