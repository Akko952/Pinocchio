<?xml version="1.0" ?>
<robot name="3_SPR_Parallel_Robot">

  <!-- Materials -->
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1"/></material>
  <material name="cyan"><color rgba="0.0 0.8 0.8 1"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 0.7"/></material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.2" radius="4.5"/></geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="1000.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="200"/>
    </inertial>
  </link>
  
  <!-- ==================== LEG 1 (Connected to Platform) ==================== -->
  <!-- S-Joint 1-3 -->
  <joint name="leg1_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg1_link1"/>
    <origin xyz="3.887 0 0" rpy="0 0 0"/> <!-- 0 degrees -->
    <axis xyz="0.866025 0 -0.5"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg1_link1">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <joint name="leg1_joint2" type="revolute">
    <parent link="leg1_link1"/>
    <child link="leg1_link2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg1_link2">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <joint name="leg1_joint3" type="revolute">
    <parent link="leg1_link2"/>
    <child link="leg1_s_joint_end"/>
    <axis xyz="-0.5 0 -0.866025"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg1_s_joint_end"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <!-- P-Joint -->
  <joint name="leg1_joint4" type="prismatic">
    <parent link="leg1_s_joint_end"/>
    <child link="leg1_lower"/>
    <origin xyz="0 0 0" rpy="0 0.523599 0"/> 
    <axis xyz="0 0 -1"/>
    <limit lower="-1" upper="2.0" effort="5000" velocity="2.0"/>
  </joint>
  <link name="leg1_lower">
    <visual>
      <origin xyz="0 0 -2.8867" rpy="0 0 0"/>
      <geometry><cylinder length="5.7735" radius="0.1"/></geometry>
      <material name="cyan"/>
    </visual>
    <inertial><mass value="15.0"/><origin xyz="0 0 -2.8867"/><inertia ixx="0.8" ixy="0" ixz="0" iyy="0.8" iyz="0" izz="0.05"/></inertial>
  </link>

  <!-- R-Joint (Connected to Platform) -->
  <joint name="leg1_joint5" type="revolute">
    <parent link="leg1_lower"/>
    <child link="motion_link"/>
    <origin xyz="0 0 -5.7735" rpy="1.570796 -0.523599 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>

  <!-- ==================== MOVING PLATFORM ==================== -->
  <link name="motion_link">
    <visual>
      <!-- Platform is a disk, center it relative to Leg 1 connection -->
      <origin xyz="-1 0 0" rpy="1.570796 0 0"/>
      <geometry><cylinder length="0.2" radius="1.5"/></geometry>
      <material name="red"/>
    </visual>
    <inertial>
      <mass value="50.0"/>
      <origin xyz="-1 0 0"/>
      <inertia ixx="5" ixy="0" ixz="0" iyy="5" iyz="0" izz="10"/>
    </inertial>
    <!-- Define connection points for Leg 2 and Leg 3 on the platform -->
    <collision><geometry><cylinder length="0.2" radius="1.5"/></geometry></collision>
  </link>

  <!-- ==================== LEG 2 (Open Chain) ==================== -->
  <joint name="leg2_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg2_link1"/>
    <!-- Rotated 120 degrees: x = 3.887*cos(120) = -1.9435, y = 3.887*sin(120) = 3.3662 -->
    <origin xyz="-1.9435 3.3662 0" rpy="0 0 2.0944"/> 
    <axis xyz="0.866025 0 -0.5"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg2_link1"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <joint name="leg2_joint2" type="revolute">
    <parent link="leg2_link1"/><child link="leg2_link2"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="100" velocity="1"/></joint>
  <link name="leg2_link2"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <joint name="leg2_joint3" type="revolute">
    <parent link="leg2_link2"/><child link="leg2_s_joint_end"/><axis xyz="-0.5 0 -0.866025"/><limit lower="-1.57" upper="1.57" effort="100" velocity="1"/></joint>
  <link name="leg2_s_joint_end"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <joint name="leg2_joint4" type="prismatic">
    <parent link="leg2_s_joint_end"/><child link="leg2_lower"/><origin xyz="0 0 0" rpy="0 0.523599 0"/><axis xyz="0 0 -1"/><limit lower="-1" upper="2.0" effort="5000" velocity="2.0"/></joint>
  <link name="leg2_lower">
    <visual><origin xyz="0 0 -2.8867" rpy="0 0 0"/><geometry><cylinder length="5.7735" radius="0.1"/></geometry><material name="cyan"/></visual>
    <inertial><mass value="15.0"/><origin xyz="0 0 -2.8867"/><inertia ixx="0.8" ixy="0" ixz="0" iyy="0.8" iyz="0" izz="0.05"/></inertial>
  </link>

  <!-- Leg 2 ends with an R-joint, but the child is a dummy link (tip) -->
  <joint name="leg2_joint5" type="revolute">
    <parent link="leg2_lower"/>
    <child link="leg2_tip"/>
    <origin xyz="0 0 -5.7735" rpy="1.570796 -0.523599 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg2_tip">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <!-- ==================== LEG 3 (Open Chain) ==================== -->
  <joint name="leg3_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="leg3_link1"/>
    <!-- Rotated 240 degrees: x = -1.9435, y = -3.3662 -->
    <origin xyz="-1.9435 -3.3662 0" rpy="0 0 4.1888"/> 
    <axis xyz="0.866025 0 -0.5"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg3_link1"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <joint name="leg3_joint2" type="revolute">
    <parent link="leg3_link1"/><child link="leg3_link2"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="100" velocity="1"/></joint>
  <link name="leg3_link2"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <joint name="leg3_joint3" type="revolute">
    <parent link="leg3_link2"/><child link="leg3_s_joint_end"/><axis xyz="-0.5 0 -0.866025"/><limit lower="-1.57" upper="1.57" effort="100" velocity="1"/></joint>
  <link name="leg3_s_joint_end"><inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial></link>

  <joint name="leg3_joint4" type="prismatic">
    <parent link="leg3_s_joint_end"/><child link="leg3_lower"/><origin xyz="0 0 0" rpy="0 0.523599 0"/><axis xyz="0 0 -1"/><limit lower="-1" upper="2.0" effort="5000" velocity="2.0"/></joint>
  <link name="leg3_lower">
    <visual><origin xyz="0 0 -2.8867" rpy="0 0 0"/><geometry><cylinder length="5.7735" radius="0.1"/></geometry><material name="cyan"/></visual>
    <inertial><mass value="15.0"/><origin xyz="0 0 -2.8867"/><inertia ixx="0.8" ixy="0" ixz="0" iyy="0.8" iyz="0" izz="0.05"/></inertial>
  </link>

  <joint name="leg3_joint5" type="revolute">
    <parent link="leg3_lower"/>
    <child link="leg3_tip"/>
    <origin xyz="0 0 -5.7735" rpy="1.570796 -0.523599 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  </joint>
  <link name="leg3_tip">
    <inertial><mass value="0.01"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

</robot>